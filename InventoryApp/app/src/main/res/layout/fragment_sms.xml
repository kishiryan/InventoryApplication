<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvSmsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sms"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/txtSmsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/smsAlerts"
            android:layout_marginTop="24dp"
            android:layout_marginStart="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvSmsTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <Button
            android:id="@+id/btnSmsPermission"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/enableSMSPermission"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="48dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/txtSmsStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="320dp"/>

        <Button
            android:id="@+id/btnSendAlerts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/sendLowInventoryAlerts"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="48dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnSmsPermission"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="320dp"/>

        <TextView
            android:id="@+id/tvSmsAlertsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/smsLowInventory"
            android:layout_marginTop="24dp"
            android:layout_marginStart="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnSendAlerts"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/lowInventoryAlerts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvSmsAlertsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>